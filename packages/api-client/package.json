{
  "name": "@tasheen/api-client",
  "version": "0.0.0",
  "private": true,
  "description": "Auto-generated SDK for the Tasheen Fastify backend. Regenerate via `pnpm --filter @tasheen/api-client generate`.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "openapi-typescript http://localhost:3000/docs/json -o ./src/generated/schema.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@tasheen/types": "workspace:*"
  },
  "devDependencies": {
    "@tasheen/config": "workspace:*",
    "openapi-fetch": "^0.12.2",
    "openapi-typescript": "^7.4.4",
    "typescript": "^5.9.3"
  }
}
