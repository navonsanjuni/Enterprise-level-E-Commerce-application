{
  "name": "tasheen-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Tasheen — enterprise-level e-commerce monorepo (backend + storefront + admin).",
  "type": "commonjs",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npx tsx watch apps/api/src/index.ts",
    "dev:web": "turbo run dev --filter=@tasheen/web",
    "dev:admin": "turbo run dev --filter=@tasheen/admin",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "build:api": "npx tsc --noEmit",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "api:check": "npx tsc --noEmit --ignoreDeprecations 5.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tasheen2002/Enterprise-level-E-Commerce-application.git"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Tasheen2002/Enterprise-level-E-Commerce-application/issues"
  },
  "homepage": "https://github.com/Tasheen2002/Enterprise-level-E-Commerce-application#readme",
  "devDependencies": {
    "@prisma/client": "^6.16.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.3",
    "@types/qrcode": "^1.5.6",
    "@types/sanitize-html": "^2.16.1",
    "@types/speakeasy": "^2.0.10",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.16.1",
    "tsx": "^4.21.0",
    "turbo": "^2.3.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "sanitize-html": "^2.17.3",
    "speakeasy": "^2.0.0",
    "stripe": "^20.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.5"
  },
  "packageManager": "pnpm@9.12.0"
}
